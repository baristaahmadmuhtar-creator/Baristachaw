{
  "cli": {
    "version": ">= 16.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "ios_internal": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://baristaclaw.vercel.app",
        "EXPO_PUBLIC_WEB_APP_URL": "https://baristaclaw.vercel.app",
        "EXPO_PUBLIC_APP_SCHEME": "baristachaw",
        "EXPO_PUBLIC_MOBILE_UI_MODE": "web_parity",
        "EXPO_PUBLIC_WEB_PARITY_TIMEOUT_MS": "10000",
        "EXPO_PUBLIC_WEB_PARITY_FALLBACK_ENABLED": "false",
        "EXPO_PUBLIC_ENABLE_GUEST_MODE": "true",
        "EXPO_PUBLIC_ENABLE_APPLE_SIGNIN": "true",
        "EXPO_PUBLIC_RELEASE": "ios-internal-qa"
      },
      "ios": {
        "autoIncrement": "buildNumber"
      }
    },
    "mvp_android": {
      "credentialsSource": "local",
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://baristaclaw.vercel.app",
        "EXPO_PUBLIC_WEB_APP_URL": "https://baristaclaw.vercel.app",
        "EXPO_PUBLIC_APP_SCHEME": "baristachaw",
        "EXPO_PUBLIC_MOBILE_UI_MODE": "web_parity",
        "EXPO_PUBLIC_WEB_PARITY_TIMEOUT_MS": "10000",
        "EXPO_PUBLIC_WEB_PARITY_FALLBACK_ENABLED": "false",
        "EXPO_PUBLIC_ENABLE_GUEST_MODE": "true",
        "EXPO_PUBLIC_ENABLE_APPLE_SIGNIN": "false",
        "EXPO_PUBLIC_RELEASE": "android-mvp-production"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://baristaclaw.vercel.app",
        "EXPO_PUBLIC_WEB_APP_URL": "https://baristaclaw.vercel.app",
        "EXPO_PUBLIC_APP_SCHEME": "baristachaw",
        "EXPO_PUBLIC_MOBILE_UI_MODE": "web_parity",
        "EXPO_PUBLIC_WEB_PARITY_TIMEOUT_MS": "10000",
        "EXPO_PUBLIC_WEB_PARITY_FALLBACK_ENABLED": "false",
        "EXPO_PUBLIC_ENABLE_GUEST_MODE": "true",
        "EXPO_PUBLIC_ENABLE_APPLE_SIGNIN": "true",
        "EXPO_PUBLIC_RELEASE": "mobile-preview"
      },
      "ios": {
        "autoIncrement": "buildNumber"
      },
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": "versionCode"
      }
    },
    "production": {
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://baristaclaw.vercel.app",
        "EXPO_PUBLIC_WEB_APP_URL": "https://baristaclaw.vercel.app",
        "EXPO_PUBLIC_APP_SCHEME": "baristachaw",
        "EXPO_PUBLIC_MOBILE_UI_MODE": "web_parity",
        "EXPO_PUBLIC_WEB_PARITY_TIMEOUT_MS": "10000",
        "EXPO_PUBLIC_WEB_PARITY_FALLBACK_ENABLED": "false",
        "EXPO_PUBLIC_ENABLE_GUEST_MODE": "true",
        "EXPO_PUBLIC_ENABLE_APPLE_SIGNIN": "true",
        "EXPO_PUBLIC_RELEASE": "mobile-production"
      },
      "ios": {
        "autoIncrement": "buildNumber"
      },
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": "versionCode"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {},
      "android": {
        "track": "internal"
      }
    },
    "production": {
      "ios": {},
      "android": {
        "track": "internal"
      }
    }
  }
}
