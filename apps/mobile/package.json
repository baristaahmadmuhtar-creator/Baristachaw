{
  "name": "@baristachaw/mobile",
  "version": "1.0.2",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "doctor": "npx -y expo-doctor",
    "eas:build:ios-internal": "npx eas build --platform ios --profile ios_internal",
    "eas:build:android-mvp": "npx eas build --platform android --profile mvp_android",
    "eas:build:android-preview": "npx eas build --platform android --profile preview",
    "eas:build:android-production": "npx eas build --platform android --profile production",
    "eas:build:ios-preview": "npx eas build --platform ios --profile preview",
    "eas:submit:ios-preview": "npx eas submit --platform ios --profile preview",
    "eas:build:ios-production": "npx eas build --platform ios --profile production",
    "eas:submit:ios-production": "npx eas submit --platform ios --profile production",
    "eas:build:preview": "npm run eas:build:ios-preview",
    "eas:submit:preview": "npm run eas:submit:ios-preview",
    "eas:build:production": "npm run eas:build:ios-production",
    "eas:submit:production": "npm run eas:submit:ios-production",
    "test": "jest --passWithNoTests",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@baristachaw/design-tokens": "file:./packages/design-tokens",
    "@baristachaw/shared": "file:./packages/shared",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.104.0",
    "expo": "~54.0.35",
    "expo-apple-authentication": "~8.0.7",
    "expo-auth-session": "~7.0.11",
    "expo-av": "~16.0.8",
    "expo-camera": "~17.0.8",
    "expo-crypto": "~15.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.7",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-network": "~8.0.7",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "jest": "^29.2.1",
    "jest-expo": "~54.0.17",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "private": true
}
