{
    "name": "baristachaw",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "engines": {
        "node": ">=24.0.0",
        "npm": ">=11.0.0"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "tsx server.ts",
        "dev:web": "npm run dev --workspace @baristachaw/web",
        "build": "npm run build --workspace @baristachaw/web",
        "generate:icons": "node scripts/generate-icons.mjs",
        "catalog:bootstrap": "tsx scripts/catalog/bootstrap-phase1.ts",
        "catalog:build": "tsx scripts/catalog/build-phase1.ts",
        "catalog:audit:grinders": "tsx scripts/catalog/audit-grinder-catalog.ts",
        "catalog:audit:waters": "tsx scripts/catalog/audit-water-catalog.ts",
        "catalog:audit": "npm run catalog:audit:grinders && npm run catalog:audit:waters",
        "catalog:audit:report": "tsx scripts/catalog/audit-grinder-catalog.ts --report-dir=artifacts/ai-brew-audit && tsx scripts/catalog/audit-water-catalog.ts --report-dir=artifacts/ai-brew-audit && tsx scripts/catalog/build-ai-brew-data-quality-report.ts --report-dir=artifacts/ai-brew-audit",
        "preview": "npm run preview --workspace @baristachaw/web",
        "start": "tsx server.ts",
        "lint": "npm run lint:root && npm run lint --workspace @baristachaw/design-tokens && npm run lint --workspace @baristachaw/shared && npm run lint --workspace @baristachaw/web",
        "lint:root": "tsc --noEmit -p tsconfig.json",
        "check": "npm run lint && npm run build",
        "smoke:local": "node scripts/smoke-local.mjs",
        "smoke:prod": "node scripts/smoke-prod.mjs",
        "smoke:prod:auth": "node scripts/smoke-prod.mjs --require-auth",
        "supabase:quota:verify": "node scripts/verify-supabase-quota-rpc.mjs",
        "prod:env:check": "node scripts/check-production-env.mjs",
        "launch:doctor": "node scripts/launch-readiness.mjs",
        "release:verify": "node scripts/check-release.mjs",
        "clean": "rm -rf dist apps/web/dist",
        "test:e2e:install": "playwright install --with-deps chromium firefox webkit",
        "test:e2e": "playwright test tests/e2e --project=chromium --project=firefox --project=webkit",
        "test:e2e:mobile": "playwright test tests/e2e/mobile.spec.ts --project=\"Mobile Chrome\" --project=\"Mobile Safari\"",
        "test:e2e:switch": "playwright test tests/e2e/tools.spec.ts --project=chromium -g \"Hario Switch|MUGEN|Switch\"",
        "test:e2e:switch:mobile": "playwright test tests/e2e/mobile.spec.ts --project=\"Mobile Chrome\" --project=\"Mobile Safari\" -g \"ai brew\"",
        "test:e2e:prod": "LIVE_E2E=1 playwright test tests/e2e --project=chromium --project=firefox --project=webkit",
        "test:a11y": "playwright test tests/a11y --project=chromium",
        "test:a11y:prod": "LIVE_E2E=1 playwright test tests/a11y --project=chromium",
        "test:ai-brew": "node --experimental-strip-types --import ./tests/unit/register-sandbox-loader.mjs --test --test-isolation=none tests/unit/aiBrew*.test.ts",
        "test:ai-brew:switch": "node --experimental-strip-types --import ./tests/unit/register-sandbox-loader.mjs --test --test-isolation=none --test-name-pattern=\"Hario Switch|Switch\" tests/unit/aiBrew*.test.ts",
        "test:unit": "node --experimental-strip-types --import ./tests/unit/register-sandbox-loader.mjs --test --test-isolation=none tests/unit/**/*.test.ts",
        "test:unit:sandbox": "node --experimental-strip-types --import ./tests/unit/register-sandbox-loader.mjs --test --test-isolation=none tests/unit/**/*.test.ts",
        "test:mobile-parity:unit": "node --experimental-strip-types --import ./tests/unit/register-sandbox-loader.mjs --test --test-isolation=none tests/unit/mobileWebParity*.test.ts",
        "test:mobile-parity:e2e": "playwright test tests/e2e/mobile-web-parity.ai-brew.spec.ts tests/e2e/mobile-web-parity.errors.spec.ts tests/e2e/mobile-web-parity.language.spec.ts tests/e2e/mobile-web-parity.navigation.spec.ts tests/e2e/mobile-web-parity.no-dead-feature.spec.ts tests/e2e/mobile-web-parity.safe-area.spec.ts tests/e2e/mobile-web-parity.storage.spec.ts --project=\"Mobile Chrome\" --project=\"Mobile Safari\"",
        "test:mobile-parity": "npm run test:mobile-parity:unit && npm run test:mobile-parity:e2e",
        "test:perf": "node tests/perf/run-lighthouse.mjs",
        "test:gate:local": "node scripts/run-local-gate.mjs",
        "test:prod:gate": "node scripts/run-prod-gate.mjs",
        "mobile:start": "npm run start --workspace @baristachaw/mobile",
        "mobile:start:dev-client": "npm run start:dev-client --workspace @baristachaw/mobile",
        "mobile:ios": "npm run ios --workspace @baristachaw/mobile",
        "mobile:doctor": "npm run doctor --workspace @baristachaw/mobile",
        "mobile:auth:check": "node scripts/check-mobile-auth-env.mjs",
        "mobile:test": "npm run test --workspace @baristachaw/mobile",
        "mobile:lint": "npm run lint --workspace @baristachaw/mobile",
        "mobile:eas:build:preview": "npm run eas:build:preview --workspace @baristachaw/mobile",
        "mobile:eas:submit:preview": "npm run eas:submit:preview --workspace @baristachaw/mobile",
        "mobile:eas:build:production": "npm run eas:build:production --workspace @baristachaw/mobile",
        "mobile:eas:submit:production": "npm run eas:submit:production --workspace @baristachaw/mobile",
        "mobile:eas:build:android-mvp": "npm run eas:build:android-mvp --workspace @baristachaw/mobile",
        "mobile:eas:build:android-preview": "npm run eas:build:android-preview --workspace @baristachaw/mobile",
        "mobile:eas:build:android-production": "npm run eas:build:android-production --workspace @baristachaw/mobile",
        "mobile:eas:build:ios-preview": "npm run eas:build:ios-preview --workspace @baristachaw/mobile",
        "mobile:eas:build:ios-production": "npm run eas:build:ios-production --workspace @baristachaw/mobile",
        "catalog:import:id-water": "tsx scripts/catalog/import-indonesia-water-dataset.ts",
        "catalog:import:global-water": "tsx scripts/catalog/import-global-water-gh-kh.ts"
    },
    "dependencies": {
        "@baristachaw/shared": "*",
        "@google/genai": "^1.29.0",
        "cookie-parser": "^1.4.7",
        "dotenv": "^17.2.3",
        "express": "^4.21.2",
        "firebase": "^12.9.0",
        "jose": "^6.1.0",
        "jsonwebtoken": "^9.0.3"
    },
    "overrides": {
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "react-native": "0.81.5",
        "express": {
            "path-to-regexp": "0.1.13"
        },
        "brace-expansion": "2.0.3",
        "undici": "6.24.0",
        "postcss": "8.5.10"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.1",
        "@playwright/test": "^1.58.2",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.14.0",
        "@vercel/node": "^5.6.9",
        "axe-core": "^4.11.1",
        "chrome-launcher": "^1.2.1",
        "lighthouse": "^13.0.3",
        "metro": "^0.76.8",
        "metro-config": "^0.76.8",
        "pngjs": "^3.4.0",
        "tsx": "^4.21.0",
        "typescript": "~5.8.2",
        "vite": "6.4.2"
    }
}
