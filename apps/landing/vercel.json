{
  "framework": "vite",
  "buildCommand": "npm run build --workspace @baristachaw/landing",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "redirects": [
    { "source": "/app", "destination": "https://app.baristachaw.com", "permanent": false },
    { "source": "/tools", "destination": "https://app.baristachaw.com/tools", "permanent": false },
    { "source": "/login", "destination": "https://app.baristachaw.com/login", "permanent": false },
    { "source": "/register", "destination": "https://app.baristachaw.com/register", "permanent": false },
    { "source": "/ai-brew", "destination": "https://app.baristachaw.com/tools?tab=ai_brew", "permanent": false }
  ],
  "rewrites": [
    { "source": "/:path*", "destination": "/" }
  ]
}
