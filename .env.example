# Baristachaw production environment example.
# Copy real values into Vercel environment variables or .env.production.local.
# Never commit real secrets. Values prefixed with VITE_ or EXPO_PUBLIC_ are public.

# Runtime
NODE_ENV=production
APP_URL=https://app.baristachaw.com
ALLOWED_ORIGINS=https://app.baristachaw.com
JWT_SECRET=
ADMIN_EMAILS=
HEALTHCHECK_TOKEN=

# AI providers
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_AI_COACH_MODEL=gpt-5.4-mini
OPENAI_AI_COACH_MAX_OUTPUT_TOKENS=360
OPENAI_AI_COACH_REASONING_EFFORT=low
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=

# Supabase server-side keys
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Social login providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_GRAPH_API_VERSION=v25.0

# Public web config
VITE_APP_URL=https://app.baristachaw.com
VITE_PUBLIC_APP_URL=https://app.baristachaw.com
VITE_SITE_URL=https://baristachaw.com
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SENTRY_DSN=
VITE_RELEASE=production

# Billing enforcement
PLAN_ENFORCEMENT_ENABLED=false
PLAN_QUOTA_STRICT_ENABLED=false
BILLING_LIVE_MODE=false

# Checkout URLs used by server-api/billing/checkout.ts.
# Use provider-hosted links first for MVP, then add webhooks when provider account is live.
BILLING_CHECKOUT_URL=
BILLING_CHECKOUT_URL_STARTER=
BILLING_CHECKOUT_URL_PRO=
BILLING_CHECKOUT_URL_TEAM=
BILLING_CHECKOUT_URL_ENTERPRISE=
BILLING_PORTAL_URL=

# Stripe, optional for global card checkout.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_URL_STARTER=
STRIPE_CHECKOUT_URL_PRO=
STRIPE_CHECKOUT_URL_TEAM=
STRIPE_CUSTOMER_PORTAL_URL=

# Midtrans, optional for Indonesia web/manual invoice.
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_WEBHOOK_SECRET=
MIDTRANS_ENV=sandbox

# Xendit, optional for Indonesia web/manual invoice.
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
XENDIT_ENV=sandbox

# Mayar, optional for Indonesia web checkout.
# Checkout creation uses official invoice endpoint. Webhook entitlement is blocked
# until Mayar publishes an official signature verification method.
MAYAR_API_KEY=
MAYAR_WEBHOOK_SECRET=
MAYAR_ENV=sandbox
MAYAR_BASE_URL=
MAYAR_SUCCESS_URL=https://app.baristachaw.com/billing/success
MAYAR_CANCEL_URL=https://app.baristachaw.com/billing/cancel
MAYAR_WEBHOOK_PATH=/api/billing/mayar-webhook
MAYAR_CHECKOUT_ENABLED=false

# RevenueCat, optional for shared mobile entitlement management.
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_CHECKOUT_URL_STARTER=
REVENUECAT_CHECKOUT_URL_PRO=
REVENUECAT_CHECKOUT_URL_TEAM=
REVENUECAT_CUSTOMER_CENTER_URL=

# Mobile auth bridge
MOBILE_APP_SCHEME=baristachaw
MOBILE_AUTH_GRANT_TTL_SEC=300

# Store / native billing metadata.
GOOGLE_PLAY_PACKAGE_NAME=com.baristachaw.mobile
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_PRIVATE_KEY=
APP_STORE_SHARED_SECRET=
APPLE_APP_ID=

# Monitoring
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=baristachaw
SENTRY_RELEASE=production
